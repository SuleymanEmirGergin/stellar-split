{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/frontend-backend-handoff.schema.json",
  "title": "Frontend to Backend Handoff Schema",
  "description": "Structured handoff contract from a frontend/design agent to a backend/integration agent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pages",
    "forms",
    "tables",
    "actions",
    "authFlows",
    "externalTriggers",
    "assumptions"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "description": "Optional metadata about the handoff file generation.",
      "additionalProperties": true,
      "properties": {
        "version": { "type": "string" },
        "generatedBy": { "type": "string" },
        "generatedAt": { "type": "string" },
        "projectName": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "frontendStack": {
          "type": "string"
        },
        "backendStackPreference": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "deploymentTarget": {
          "type": "string",
          "description": "Target deployment platform hint for the backend integrator."
        },
        "complianceScope": {
          "type": "string",
          "enum": ["HIPAA", "PCI-DSS", "SOC2", "GDPR", "none"],
          "description": "Regulatory compliance scope. Triggers compliance.md playbook in Backend Integrator. Use 'none' to explicitly declare no regulated data."
        },
        "observabilityBaseline": {
          "type": "object",
          "additionalProperties": false,
          "description": "Optional upfront declaration of observability requirements.",
          "properties": {
            "healthEndpoints": { "type": "boolean" },
            "structuredLogging": { "type": "boolean" },
            "distributedTracing": { "type": "boolean" },
            "metricsEnabled": { "type": "boolean" }
          }
        }
      }
    },
    "pages": {
      "type": "array",
      "items": { "$ref": "#/definitions/page" }
    },
    "forms": {
      "type": "array",
      "items": { "$ref": "#/definitions/form" }
    },
    "tables": {
      "type": "array",
      "items": { "$ref": "#/definitions/table" }
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/definitions/action" }
    },
    "authFlows": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          { "$ref": "#/definitions/authFlow" }
        ]
      }
    },
    "uploads": {
      "type": "array",
      "items": { "$ref": "#/definitions/upload" }
    },
    "externalTriggers": {
      "type": "array",
      "items": { "$ref": "#/definitions/externalTrigger" }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          { "type": "object", "additionalProperties": true }
        ]
      }
    }
  },
  "definitions": {
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "route": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1, "description": "Alias for route." },
        "purpose": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "description": "Alias for purpose." },
        "requiresAuth": { "type": "boolean", "default": false },
        "roles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dataDependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "components": {
          "type": "array",
          "items": { "type": "string" }
        },
        "emptyStates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "errorStates": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "form": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fields"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "description": "Alias for name." },
        "page": { "type": "string", "minLength": 1 },
        "submitAction": { "type": "string", "minLength": 1 },
        "endpoint": { "type": "string", "description": "Alias for submitAction." },
        "method": { "type": "string", "description": "HTTP method hint (alias for methodHint)." },
        "methodHint": { "type": "string", "description": "HTTP method hint. E.g. GET, POST, PUT, PATCH, DELETE, POST/PATCH." },
        "roles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "note": { "type": "string" },
        "validations": {
          "oneOf": [
            { "type": "object", "additionalProperties": true },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/field" }
        },
        "successBehavior": { "type": "string" },
        "errorBehavior": { "type": "string" }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "required"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "text", "textarea", "email", "password", "number", "boolean",
            "select", "multiselect", "date", "datetime", "datetime-local",
            "time", "file", "image", "phone", "url", "json",
            "checkbox", "checkbox-group", "radio", "radio-group",
            "toggle", "range", "rating", "tags", "rich-text", "hidden",
            "color", "duration", "markdown"
          ]
        },
        "required": { "type": "boolean" },
        "description": { "type": "string" },
        "note": { "type": "string" },
        "notes": { "type": "string" },
        "maxLength": { "type": "integer", "minimum": 0 },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "minLength": { "type": "integer", "minimum": 0 },
            "maxLength": { "type": "integer", "minimum": 0 },
            "min": { "type": "number" },
            "max": { "type": "number" },
            "pattern": { "type": "string" },
            "format": { "type": "string" },
            "note": { "type": "string" },
            "mimeTypes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "maxSizeMB": { "type": "number", "minimum": 0 }
          }
        },
        "options": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mapsToEntity": { "type": "string" }
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columns"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "description": "Alias for name." },
        "page": { "type": "string", "minLength": 1 },
        "dataSource": { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "type": "string" },
              { "$ref": "#/definitions/column" }
            ]
          }
        },
        "supportsPagination": { "type": "boolean", "default": false },
        "supportsSearch": { "type": "boolean", "default": false },
        "supportsSort": { "type": "boolean", "default": false },
        "supportsFilters": { "type": "boolean", "default": false },
        "rowActions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "key": { "type": "string", "description": "Alias for name." },
        "label": { "type": "string", "description": "Display label (alias for name)." },
        "type": {
          "type": "string",
          "enum": [
            "text", "number", "date", "datetime", "badge", "badge-list",
            "image", "boolean", "currency", "custom", "actions",
            "toggle", "link", "url", "avatar", "tags", "json", "enum", "time"
          ]
        },
        "sortable": { "type": "boolean", "default": false },
        "filterable": { "type": "boolean", "default": false }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "description": "Alias for name." },
        "label": { "type": "string", "description": "Display label." },
        "page": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": [
            "create", "read", "update", "delete",
            "bulk-update", "bulk-delete",
            "export", "import", "custom",
            "button", "copy", "share", "navigate",
            "toggle-status", "close", "open", "archive"
          ]
        },
        "target": { "type": "string", "minLength": 1 },
        "endpoint": { "type": "string" },
        "description": { "type": "string" },
        "requiresConfirmation": { "type": "boolean", "default": false },
        "confirmRequired": { "type": "boolean", "default": false },
        "confirmationMessage": { "type": "string" },
        "sideEffects": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "authFlow": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "login", "register", "logout",
            "refresh", "refresh-token",
            "forgot-password", "reset-password",
            "email-verification", "2fa",
            "role-based-access", "oauth", "sso",
            "magic-link", "phone-otp"
          ]
        },
        "name": { "type": "string", "description": "Alias for type." },
        "endpoint": { "type": "string" },
        "notes": { "type": "string" },
        "protectedPages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "roles": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "upload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "page", "fileTypes"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "page": { "type": "string", "minLength": 1 },
        "fileTypes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "maxSizeMB": { "type": "number", "minimum": 0 },
        "multiple": { "type": "boolean", "default": false },
        "storageHint": { "type": "string" },
        "visibility": {
          "type": "string",
          "enum": ["public", "private", "signed-url", "unknown"]
        },
        "endpoint": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "externalTrigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": [
            "payment-webhook", "email-send", "sms-send",
            "push-notification", "third-party-api-call",
            "cron-job", "cron", "queue-job",
            "analytics-event", "custom",
            "video-webhook", "scheduled-job",
            "storage-event", "realtime-event",
            "webhook"
          ]
        },
        "providerHint": { "type": "string" },
        "triggerSource": { "type": "string" },
        "expectedOutcome": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
