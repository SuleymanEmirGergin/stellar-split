  },
  "project": {
    "name": "StellarSplit",
    "description": "Decentralized group expense splitting dApp on Stellar blockchain. NestJS API + BullMQ workers + PostgreSQL + Redis.",
    "repoType": "monorepo",
    "deploymentTarget": "railway",
    "runtime": "node",
    "language": "TypeScript",
    "framework": "NestJS 10",
    "packageManager": "npm",
    "monorepo": true
  },
  "frontend": {
    "framework": "React 18 + Vite + TypeScript",
    "apps": [
      {
        "name": "web",
        "path": "frontend/"
      }
    ]
  },
  "backend": {
    "framework": "NestJS 10",
    "language": "typescript",
    "database": "PostgreSQL 15",
    "orm": "Prisma 5",
    "auth": "SIWS (Sign In With Stellar) + JWT",
    "authStrategy": "Passport JWT — wallet signature verification, no passwords",
    "roles": ["member", "creator", "guardian"],
    "entities": [
      "User",
      "Group",
      "GroupMember",
      "Expense",
      "ExpenseSplit",
      "Settlement",
      "RecurringTemplate",
      "Guardian",
      "RecoveryRequest",
      "Notification",
      "AnalyticsEvent",
      "RefreshToken"
    ],
    "services": [
      {
        "name": "api",
        "type": "api",
        "path": "backend/src",
        "port": 3001,
        "entryPoint": "backend/src/main.ts",
        "startCommand": "node dist/main.js",
        "description": "NestJS REST API — groups, expenses, settlements, auth, uploads, reputation",
        "endpoints": [
          "GET /health/live",
          "GET /health/ready",
          "GET /metrics",
          "POST /auth/challenge",
          "POST /auth/verify",
          "POST /auth/refresh",
          "POST /auth/logout",
          "GET /groups",
          "POST /groups",
          "GET /groups/:id",
          "PATCH /groups/:id",
          "DELETE /groups/:id",
          "POST /groups/:id/join",
          "POST /groups/:id/leave",
          "GET /groups/:id/expenses",
          "GET /groups/:id/balances",
          "GET /groups/:id/settlements",
          "GET /groups/:id/recurring",
          "GET /groups/:id/guardians",
          "POST /expenses",
          "PATCH /expenses/:id/cancel",
          "POST /settlements",
          "POST /recurring",
          "PATCH /recurring/:id",
          "DELETE /recurring/:id",
          "POST /guardians",
          "DELETE /guardians/:id",
          "GET /reputation/me",
          "GET /reputation/badges",
          "POST /uploads/receipt",
          "GET /notifications",
          "PATCH /notifications/:id/read",
          "POST /analytics/events",
          "GET /og-image/:groupId"
        ],
        "healthCheck": {
          "path": "/health/live",
          "interval": 30,
          "timeout": 5
        }
      },
      {
        "name": "worker",
        "type": "worker",
        "path": "backend/src/workers",
        "description": "BullMQ workers: Stellar tx monitor, recurring expense scheduler, notification dispatch",
        "startCommand": "node dist/worker.js"
      }
    ]
  },
  "integrations": [
    {
      "name": "PostgreSQL",
      "type": "cache",
      "provider": "Railway PostgreSQL plugin",
      "envVarsRequired": ["DATABASE_URL"]
    },
    {
      "name": "Redis",
      "type": "queue",
      "provider": "Railway Redis plugin",
      "envVarsRequired": ["REDIS_URL"]
    },
    {
      "name": "S3-compatible Storage",
      "type": "storage",
      "provider": "Cloudflare R2 or AWS S3",
      "envVarsRequired": [
        "S3_ENDPOINT",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "S3_BUCKET_NAME",
        "S3_REGION",
        "S3_PUBLIC_URL"
      ]
    },
    {
      "name": "Stellar Horizon API",
      "type": "custom",
      "provider": "Stellar Development Foundation",
      "envVarsRequired": ["STELLAR_NETWORK", "STELLAR_HORIZON_URL"]
    },
    {
      "name": "Soroban RPC",
      "type": "custom",
      "provider": "Stellar Soroban RPC",
      "envVarsRequired": ["SOROBAN_RPC_URL", "SOROBAN_CONTRACT_ID"]
    },
    {
      "name": "CoinGecko Price Feed",
      "type": "custom",
      "provider": "CoinGecko",
      "envVarsRequired": ["COINGECKO_API_KEY"]
    },
    {
      "name": "Discord Webhook",
      "type": "push-notification",
      "provider": "Discord",
      "envVarsRequired": ["DISCORD_WEBHOOK_URL", "DISCORD_WEBHOOK_SECRET"]
    },
    {
      "name": "Slack Webhook",
      "type": "push-notification",
      "provider": "Slack",
      "envVarsRequired": ["SLACK_WEBHOOK_URL", "SLACK_WEBHOOK_SECRET"]
    },
    {
      "name": "Web Push (VAPID)",
      "type": "push-notification",
      "provider": "Web Push API",
      "envVarsRequired": ["VAPID_PUBLIC_KEY", "VAPID_PRIVATE_KEY", "VAPID_EMAIL"]
    },
    {
      "name": "Sentry Error Tracking",
      "type": "monitoring",
      "provider": "Sentry",
      "envVarsRequired": ["SENTRY_DSN"]
    }
  ],
  "infrastructure": {
    "queue": "BullMQ + Redis",
    "cache": "Redis",
    "storage": "S3-compatible (R2/S3)",
    "containerization": "docker",
    "cicd": "github-actions",
    "redisProvider": "Railway Redis plugin",
    "redisNotes": "Standard TCP Redis — works on Railway. Not Cloudflare Workers.",
    "deploymentNotes": "Single Railway service. DATABASE_URL and REDIS_URL injected via Railway environment. Health check path: /health/live."
  },
  "security": {
    "secretScanningEnabled": true,
    "securityMdIncluded": true,
    "ciSecurityScanStep": true,
    "gitignoreComprehensive": true,
    "corsWhitelistConfigured": true,
    "piiFieldsEncrypted": false,
    "fieldEncryptionAlgorithm": "none",
    "authStrategy": "SIWS + Passport JWT. Ed25519 signature verification. HttpOnly refresh-token cookie.",
    "tokenStorage": "Access token: localStorage (frontend). Refresh token: HttpOnly Secure SameSite=Strict cookie. Stored hashed in Redis.",
    "passwordHashing": "none — no passwords in SIWS auth model",
    "secretScanning": true,
    "gitleaksConfig": "backend/.gitleaks.toml",
    "dependencyAudit": "npm audit on every CI run",
    "rateLimitingEnabled": true,
    "rateLimitingStrategy": "NestJS ThrottlerModule — 10 req/min on auth endpoints; 60 req/min general; 30 req/min on upload endpoints",
    "notes": "Helmet headers. CORS origin whitelist via FRONTEND_URL env var. No raw card data. No PII email/phone collected. Wallet addresses are public keys."
  },
  "compliance": {
    "scope": "none",
    "notes": "No HIPAA, PCI, or GDPR regulated data collected. Wallet addresses are public keys. No email, phone, SSN, or card data stored."
  },
  "observability": {
    "structuredLogging": true,
    "loggingLibrary": "pino (nestjs-pino)",
    "correlationId": true,
    "correlationIdHeader": "X-Request-ID",
    "healthEndpointsPlanned": true,
    "healthEndpoints": ["GET /health/live", "GET /health/ready"],
    "healthLive": "/health/live",
    "healthReady": "/health/ready",
    "prometheusMetrics": true,
    "prometheusEndpoint": "/metrics",
    "sentryEnabled": true,
    "sentryEnvironments": ["production", "staging"],
    "distributedTracing": false,
    "distributedTracingNote": "Single-service monolith on Railway. Distributed tracing not required. Pino correlation IDs cover request tracing within the service."
  },
  "packages": [
    {
      "name": "@stellarsplit/types",
      "path": "packages/types",
      "purpose": "types",
      "consumedBy": ["frontend", "backend"]
    },
    {
      "name": "@stellarsplit/sdk",
      "path": "packages/sdk",
      "purpose": "sdk",
      "consumedBy": ["frontend"]
    }
  ],
  "databases": [
    {
      "name": "postgres",
      "type": "postgresql",
      "provider": "Railway PostgreSQL plugin",
      "orm": "Prisma 5",
      "migrationTool": "prisma migrate",
      "migrationCommand": "npx prisma migrate deploy",
      "managedBy": "Railway"
    }
  ],
  "workers": [
    {
      "name": "StellarTxMonitor",
      "queue": "stellar-tx-monitor",
      "trigger": "Settlement created event",
      "idempotency": "txHash — deduplicated by unique index in Settlement table"
    },
    {
      "name": "RecurringExpenseProcessor",
      "queue": "recurring-expenses",
      "trigger": "BullMQ repeatable job on nextDue schedule",
      "idempotency": "RecurringTemplate ID + scheduled runAt timestamp"
    },
    {
      "name": "NotificationDispatcher",
      "queue": "notifications",
      "trigger": "Domain events: expense created, settlement confirmed, member join/leave",
      "idempotency": "Notification ID"
    }
  ],
