// StellarSplit Prisma Schema — Prisma 6
// PostgreSQL 15
//
// Connection URL is read from the DATABASE_URL environment variable.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// User — identified by Stellar wallet address
// ─────────────────────────────────────────────
model User {
  id              String   @id @default(uuid())
  walletAddress   String   @unique
  reputationScore Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  groupsCreated    Group[]          @relation("GroupCreator")
  groupMemberships GroupMember[]
  expensesPaid     Expense[]        @relation("ExpensePaidBy")
  settlements      Settlement[]     @relation("SettlementSettledBy")
  guardiansOwned   Guardian[]       @relation("GuardianUser")
  guardianFor      Guardian[]       @relation("GuardianOf")
  recoveryRequests RecoveryRequest[]
  notifications    Notification[]
  refreshTokens    RefreshToken[]
  badges           UserBadge[]
  proposalsCreated  Proposal[]          @relation("ProposalCreator")
  proposalVotes     ProposalVote[]      @relation("ProposalVoter")
  disputesCreated   Dispute[]           @relation("DisputeInitiator")
  pushSubscriptions PushSubscription[]

  @@index([walletAddress])
}

// ─────────────────────────────────────────────
// Group
// ─────────────────────────────────────────────
model Group {
  id          String    @id @default(uuid())
  name        String
  currency    Currency  @default(XLM)
  isSettled   Boolean   @default(false)
  inviteCode  String    @unique @default(uuid())
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator     User              @relation("GroupCreator", fields: [createdById], references: [id])
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  recurring   RecurringTemplate[]
  guardians   Guardian[]
  proposals   Proposal[]
  disputes    Dispute[]

  @@index([createdById])
  @@index([inviteCode])
}

// ─────────────────────────────────────────────
// GroupMember — many-to-many with role
// ─────────────────────────────────────────────
model GroupMember {
  id       String          @id @default(uuid())
  groupId  String
  userId   String
  role     GroupMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

enum GroupMemberRole {
  MEMBER
  CREATOR
}

enum Currency {
  XLM
  USDC
}

// ─────────────────────────────────────────────
// Expense
// ─────────────────────────────────────────────
model Expense {
  id          String        @id @default(uuid())
  groupId     String
  description String
  amount      Decimal       @db.Decimal(18, 7)
  currency    Currency      @default(XLM)
  paidById    String
  splitType   SplitType     @default(EQUAL)
  receiptUrl  String?
  status      ExpenseStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  group  Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy User         @relation("ExpensePaidBy", fields: [paidById], references: [id])
  splits ExpenseSplit[]

  @@index([groupId])
  @@index([paidById])
  @@index([status])
}

enum SplitType {
  EQUAL
  CUSTOM
  PERCENTAGE
}

enum ExpenseStatus {
  ACTIVE
  CANCELLED
}

// ─────────────────────────────────────────────
// ExpenseSplit — individual share per member
// ─────────────────────────────────────────────
model ExpenseSplit {
  id         String   @id @default(uuid())
  expenseId  String
  userId     String
  amount     Decimal  @db.Decimal(18, 7)
  percentage Decimal? @db.Decimal(5, 2)
  isPaid     Boolean  @default(false)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// Settlement
// ─────────────────────────────────────────────
model Settlement {
  id          String           @id @default(uuid())
  groupId     String
  settledById String
  txHash      String           @unique
  amount      Decimal          @db.Decimal(18, 7)
  currency    Currency         @default(XLM)
  status      SettlementStatus @default(PENDING)
  confirmedAt DateTime?
  timestamp   DateTime         @default(now())

  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  settledBy User  @relation("SettlementSettledBy", fields: [settledById], references: [id])

  @@index([groupId])
  @@index([txHash])
  @@index([status])
}

enum SettlementStatus {
  PENDING
  CONFIRMED
  FAILED
}

// ─────────────────────────────────────────────
// RecurringTemplate
// ─────────────────────────────────────────────
model RecurringTemplate {
  id          String             @id @default(uuid())
  groupId     String
  description String
  amount      Decimal            @db.Decimal(18, 7)
  currency    Currency           @default(XLM)
  frequency   RecurringFrequency
  nextDue     DateTime
  isActive    Boolean            @default(true)
  memberIds   String[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([nextDue, isActive])
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

// ─────────────────────────────────────────────
// Guardian — social recovery
// ─────────────────────────────────────────────
model Guardian {
  id             String   @id @default(uuid())
  userId         String
  groupId        String
  guardianUserId String
  isActive       Boolean  @default(true)
  addedAt        DateTime @default(now())

  user     User  @relation("GuardianUser", fields: [userId], references: [id])
  guardian User  @relation("GuardianOf", fields: [guardianUserId], references: [id])
  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, guardianUserId, groupId])
  @@index([userId])
  @@index([groupId])
}

// ─────────────────────────────────────────────
// RecoveryRequest
// ─────────────────────────────────────────────
model RecoveryRequest {
  id          String                @id @default(uuid())
  userId      String
  groupId     String
  requestedAt DateTime              @default(now())
  status      RecoveryRequestStatus @default(PENDING)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

enum RecoveryRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────
// Notification
// ─────────────────────────────────────────────
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  payload   Json
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

// ─────────────────────────────────────────────
// PushSubscription — Web Push VAPID subscriptions
// ─────────────────────────────────────────────
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum NotificationType {
  EXPENSE_ADDED
  EXPENSE_CANCELLED
  SETTLEMENT_CONFIRMED
  MEMBER_JOINED
  MEMBER_LEFT
  RECURRING_TRIGGERED
  GUARDIAN_ADDED
  TOKEN_MINTED
}

// ─────────────────────────────────────────────
// AnalyticsEvent
// ─────────────────────────────────────────────
model AnalyticsEvent {
  id      String   @id @default(uuid())
  event   String
  userId  String?
  payload Json?
  ts      DateTime @default(now())

  @@index([event, ts])
  @@index([userId])
}

// ─────────────────────────────────────────────
// RefreshToken — stored hashed for revocation
// ─────────────────────────────────────────────
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

// ─────────────────────────────────────────────
// AuditLog — append-only, never update/delete
// ─────────────────────────────────────────────
model AuditLog {
  id            String   @id @default(uuid())
  actorType     String   // "user" | "system"
  actorId       String?  // userId (null for system events)
  actorWallet   String?  // denormalized wallet address — survives user deletion
  groupId       String?  // context group (nullable for global actions)
  entityType    String   // "group" | "expense" | "settlement" | "member" | "guardian"
  entityId      String
  action        String   // e.g. "expense.created", "settlement.confirmed"
  beforeState   Json?    // snapshot before mutation (sensitive fields redacted)
  afterState    Json?    // snapshot after mutation
  ipAddress     String?
  userAgent     String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([groupId, createdAt])
  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// Governance — Proposals, Votes, Disputes
// ─────────────────────────────────────────────
model Proposal {
  id          String         @id @default(uuid())
  groupId     String
  creatorId   String
  title       String
  description String
  status      ProposalStatus @default(ACTIVE)
  threshold   Int            @default(51)
  endsAt      DateTime
  createdAt   DateTime       @default(now())

  group   Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator User          @relation("ProposalCreator", fields: [creatorId], references: [id])
  votes   ProposalVote[]

  @@index([groupId])
  @@index([status])
}

model ProposalVote {
  id         String   @id @default(uuid())
  proposalId String
  voterId    String
  option     String   // 'yes' | 'no'
  castedAt   DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  voter    User     @relation("ProposalVoter", fields: [voterId], references: [id])

  @@unique([proposalId, voterId])
  @@index([proposalId])
}

model Dispute {
  id          String        @id @default(uuid())
  groupId     String
  initiatorId String
  expenseId   String
  amount      Decimal       @db.Decimal(18, 7)
  category    String
  description String
  status      DisputeStatus @default(OPEN)
  createdAt   DateTime      @default(now())

  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  initiator User  @relation("DisputeInitiator", fields: [initiatorId], references: [id])

  @@index([groupId])
  @@index([status])
}

enum ProposalStatus {
  ACTIVE
  PASSED
  REJECTED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  DISMISSED
}

// ─────────────────────────────────────────────
// UserBadge
// ─────────────────────────────────────────────
model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badge     String
  awardedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badge])
  @@index([userId])
}
