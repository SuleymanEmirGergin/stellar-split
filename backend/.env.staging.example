# ─────────────────────────────────────────────
# StellarSplit API — Staging Environment
# Copy to .env on your Railway staging service
# ─────────────────────────────────────────────

# Server
NODE_ENV=staging
PORT=3001
SERVICE_NAME=stellarsplit-api-staging
LOG_LEVEL=debug

# Frontend (staging CORS)
FRONTEND_URL=https://staging.stellarsplit.app

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://postgres:CHANGE_ME@staging-db-host:5432/stellarsplit_staging

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://staging-redis-host:6379

# ── Auth / JWT ───────────────────────────────
JWT_SECRET=CHANGE_ME_staging_64_char_secret_different_from_prod
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ── Stellar / Soroban ────────────────────────
# Staging always uses testnet
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_CONTRACT_ID=CHANGE_ME_STAGING_CONTRACT_ADDRESS

# ── S3 (can reuse same bucket with staging/ prefix or separate) ──
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-staging-access-key
S3_SECRET_ACCESS_KEY=your-staging-secret-key
S3_BUCKET_NAME=stellarsplit-receipts-staging
S3_REGION=auto
S3_PUBLIC_URL=https://receipts-staging.stellarsplit.app

# ── Observability ────────────────────────────
# Use a separate Sentry project or environment=staging DSN
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
APP_VERSION=staging

# ── Swagger (always enabled on staging) ──────
SWAGGER_ENABLED=true

# ── Metrics ───────────────────────────────────
METRICS_SECRET=CHANGE_ME_staging_metrics_secret

# ── Rate Limiting (relaxed for testing) ──────
THROTTLE_TTL=60
THROTTLE_LIMIT=120
