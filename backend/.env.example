# ─────────────────────────────────────────────
# StellarSplit API — Environment Variables
# Copy this file to .env and fill in all values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3001
SERVICE_NAME=stellarsplit-api
LOG_LEVEL=info

# Frontend (CORS whitelist)
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/stellarsplit

# ── Redis (BullMQ + cache) ───────────────────
REDIS_URL=redis://localhost:6379

# ── Auth / JWT ───────────────────────────────
JWT_SECRET=CHANGE_ME_minimum_64_chars_random_secret_here_00000000000000000000
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ── Stellar / Soroban ────────────────────────
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_CONTRACT_ID=CHANGE_ME_CONTRACT_ADDRESS

# ── S3-compatible Storage (Cloudflare R2 or AWS S3) ──
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=stellarsplit-receipts
S3_REGION=auto
S3_PUBLIC_URL=https://receipts.stellarsplit.app

# ── Price Feed ───────────────────────────────
COINGECKO_API_KEY=

# ── Push Notifications ───────────────────────
# Web Push (VAPID)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@stellarsplit.app

# Discord Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook
DISCORD_WEBHOOK_SECRET=your-hmac-secret

# Slack Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook
SLACK_WEBHOOK_SECRET=your-hmac-secret

# ── Observability ────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Rate Limiting ────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# ── Real-time SSE ─────────────────────────────
# Keep-alive heartbeat interval (ms) — prevents proxy timeouts
SSE_HEARTBEAT_INTERVAL_MS=25000

# ── Audit Log ─────────────────────────────────
AUDIT_LOG_RETENTION_DAYS=365

# ── Observability ──────────────────────────────
# Sentry DSN — leave empty to disable error tracking
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
APP_VERSION=1.0.0
# Prometheus scrape secret — set in your Prometheus config as Bearer token
METRICS_SECRET=
